Project Title: Student Success & Retention Analytics (SQL Case Study)

1. Identifying Duplicate Records & Nulls
-- Checking for duplicate Student IDs
SELECT student_id, COUNT(*)
FROM student_performance
GROUP BY student_id
HAVING COUNT(*) > 1;

-- Checking for critical missing values in GPA or Engagement metrics
SELECT 
    COUNT(*) - COUNT(student_id) as missing_ids,
    COUNT(*) - COUNT(gpa) as missing_gpa,
    COUNT(*) - COUNT(lms_logins_past_month) as missing_logins
FROM student_performance;

2. Outlier Detection (Integrity Check)
-- Identify students with GPA or grades outside the valid range (0-4 for GPA, 0-100 for grades)
SELECT * FROM student_performance
WHERE gpa < 0 OR gpa > 4.0 
   OR avg_course_grade < 0 OR avg_course_grade > 100;

3. Creating an "Engagement Score" 
-- Calculate a weighted engagement score to rank students
SELECT 
    student_id,
    major,
    (lms_logins_past_month * 0.4 + 
     assignment_submission_rate * 30 + 
     forum_participation_count * 0.3) AS raw_engagement_score
FROM student_performance
ORDER BY raw_engagement_score DESC;

Goal: Find students with High GPA but Low Engagement—these are students likely to burn out or leave.
SELECT 
    student_id, major, gpa, lms_logins_past_month, attendance_rate
FROM student_performance
WHERE gpa > 3.5 
  AND (lms_logins_past_month < 10 OR attendance_rate < 0.70)
  AND enrollment_status = 'Active';

5. Major-Specific GPA Percentiles
Goal: Find where a student stands relative to their peers in the same major.
SELECT 
    student_id,
    major,
    gpa,
    PERCENT_RANK() OVER (PARTITION BY major ORDER BY gpa) as gpa_percentile
FROM student_performance;

Goal: Comparing average grades between students with high vs. low forum participation.
WITH ParticipationGroups AS (
    SELECT 
        avg_course_grade,
        CASE WHEN forum_participation_count > 15 THEN 'High Participant'
             WHEN forum_participation_count BETWEEN 5 AND 15 THEN 'Medium'
             ELSE 'Low/No Participant' END AS participation_level
    FROM student_performance
)
SELECT participation_level, ROUND(AVG(avg_course_grade), 2) as avg_grade
FROM ParticipationGroups
GROUP BY participation_level;

7. Retention Risk Matrix
Goal: Create a cross-tab view of Risk Level vs. Enrollment Status.
SELECT 
    enrollment_status,
    COUNT(CASE WHEN risk_level = 'High' THEN 1 END) as high_risk_count,
    COUNT(CASE WHEN risk_level = 'Medium' THEN 1 END) as medium_risk_count,
    COUNT(CASE WHEN risk_level = 'Low' THEN 1 END) as low_risk_count
FROM student_performance
GROUP BY enrollment_status;

Goal: Identify which department needs the most tutoring resources based on average course grades.
SELECT 
    major,
    AVG(avg_course_grade) as avg_dept_grade,
    COUNT(student_id) as student_count
FROM student_performance
GROUP BY major
HAVING AVG(avg_course_grade) < (SELECT AVG(avg_course_grade) FROM student_performance)
ORDER BY avg_dept_grade ASC;

Goal: Create a list of students who have 'Leave' status but 'High' GPA (Retention targets).
SELECT student_id, major, gpa, enrollment_status
FROM student_performance
WHERE enrollment_status = 'Leave' AND gpa > 3.0;



CREATE VIEW v_student_risk_dashboard AS
SELECT 
    student_id,
    major,
    gpa,
    risk_level,
    attendance_rate,
    CASE 
        WHEN risk_level = 'High' AND attendance_rate < 0.75 THEN 'Immediate Intervention'
        WHEN risk_level = 'High' THEN 'Monitor Closely'
        WHEN risk_level = 'Medium' THEN 'Support Recommended'
        ELSE 'On Track'
    END AS action_plan
FROM student_performance;

